{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "stylens-lite-api",
	"main": "src/index.ts",
	"compatibility_date": "2025-10-11",
	"observability": {
		"enabled": true
	},
	"vars": {
		"ENV_NAME": "production",
		"MODEL_ENDPOINT_URL": "https://api.openai.com/v1",
		"OPENAI_MODEL_VERSION": "gpt-5-mini",
		"OUTFIT_PHOTOS_BUCKET_NAME": "outfit-photos",
		"R2_ACCOUNT_ID": "167f1b399b1e2edd077f392c7afbd031",
		"FREE_TIER_SESSION_LIMIT": "3"
	},
	"d1_databases": [
		{
			"binding": "gostylens_db",
			"database_name": "gostylens-db",
			"database_id": "2da1cd0b-e9e5-4c6e-a2bf-d050e2a55209"
		}
	],
	"r2_buckets": [
		{
			"binding": "OUTFIT_PHOTOS_BUCKET",
			"bucket_name": "outfit-photos",
			"remote": true
		}
	]
}